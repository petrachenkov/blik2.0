# Application Settings
APP_NAME=Блик
DEBUG=True

# Database
DATABASE_URL=sqlite+aiosqlite:///./blik.db

# JWT Settings (CHANGE IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Active Directory Settings
AD_SERVER=ldap://ad.example.com
AD_BASE_DN=DC=example,DC=com
AD_BIND_DN=CN=ServiceAccount,OU=ServiceAccounts,DC=example,DC=com
AD_BIND_PASSWORD=your-service-account-password
AD_USER_SEARCH_FILTER=(sAMAccountName={username})

# MAX Messenger Bot Settings
MAX_BOT_TOKEN=your-max-bot-token
MAX_WEBHOOK_URL=http://localhost:8000

# Web Interface
WEB_HOST=0.0.0.0
WEB_PORT=8000
